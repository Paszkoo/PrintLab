{
  "name": "3d-printer-manager",
  "version": "1.0.0",
  "description": "Aplikacja do zarządzania drukarką 3D FDM",
  "main": "public/electron.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run client\" \"wait-on http://localhost:3000 && npm run electron\"",
    "es": "cross-env DEV=true concurrently -k \"cross-env BROWSER=none DANGEROUSLY_DISABLE_HOST_CHECK=true npm run client\" \"wait-on tcp:3000 && electron .\"",
    "dist": "npm run build && electron-builder -c.extraMetadata.main=build/electron.js",
    "electron": "cross-env NODE_ENV=development ELECTRON_IS_DEV=true electron .",
    "client": "vite --port 3000",
    "build": "vite build",
    "electron-dev": "cross-env ELECTRON_IS_DEV=true electron .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mongoose": "^7.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^3.1.0",
    "concurrently": "^7.6.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "lucide-react": "^0.542.0",
    "nodemon": "^3.0.2",
    "vite": "^4.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.3dprinter.manager",
    "productName": "3D Printer Manager",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "public/electron.js",
      "server/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
